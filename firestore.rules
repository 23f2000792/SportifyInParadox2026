
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSuperAdminEmail() {
      return request.auth != null && request.auth.token.email == "23f2000792@ds.study.iitm.ac.in";
    }

    function isAdmin() {
      return isSuperAdminEmail() || exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    function isSuperAdmin() {
      return isSuperAdminEmail() || (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'super-admin');
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /trials/{trialId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /standings/{standingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /runResults/{resultId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /admins/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isSuperAdmin());
      allow write: if isSuperAdmin();
    }
    match /broadcasts/{broadcastId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /fcmTokens/{tokenId} {
      allow read: if false;
      allow create: if true; // Allow anyone to subscribe
      allow update, delete: if false;
    }
  }
}
